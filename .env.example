# --- Supabase (auth + profile storage) ---
# Project Settings -> API in your Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Market data (Financial Modeling Prep) ---
# https://site.financialmodelingprep.com/developer/docs
# Without this, the app falls back to static sample quotes so the UI still works.
FMP_API_KEY=

# --- Reasoning layer (Anthropic) ---
# https://console.anthropic.com/
# Without this, recommendations show the rule-based picks with a templated rationale
# instead of a Claude-written "why".
ANTHROPIC_API_KEY=
